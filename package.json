{
  "name": "privacy-guard-userscript",
  "version": "1.11.0",
  "description": "UserScript to enhance privacy protection across websites.",
  "type": "module",
  "scripts": {
    "prebuild": "node -e \"const fs=require('node:fs'); for (const dir of ['dist']) fs.rmSync(dir,{recursive:true,force:true});\"",
    "build": "rollup -c && prettier --write dist/*.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preinstall": "node scripts/guard-engines.js",
    "lint": "concurrently -n ESLINT,STYLELINT --raw --success=all \"npm:lint:eslint\" \"npm:lint:stylelint\"",
    "lint:eslint": "eslint . --cache --cache-strategy content --cache-location .cache/eslint/",
    "lint:fix": "eslint --fix . --cache --cache-strategy content --cache-location .cache/eslint/ && stylelint --allow-empty-input --fix \"**/*.{css,scss}\" --cache --cache-strategy content --cache-location .cache/stylelint/",
    "lint:stylelint": "stylelint --allow-empty-input \"**/*.{css,scss}\" --cache --cache-strategy content --cache-location .cache/stylelint/",
    "prepare": "husky",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --reporters=default",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:related": "node --experimental-vm-modules node_modules/jest/bin/jest.js --findRelatedTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run format:check"
  },
  "overrides": {
    "glob": "^9",
    "inflight": false,
    "npm": "^11",
    "semver-diff": false
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@html-eslint/eslint-plugin": "^0.60.0",
    "@html-eslint/parser": "^0.60.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-security": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "concurrently": "^9.2.1",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jest-extended": "^3.0.1",
    "eslint-plugin-jsdoc": "^61.7.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-yml": "^1.19.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-extended": "^7.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.3",
    "rollup-plugin-string": "^3.0.0",
    "semver": "^7.7.3",
    "stylelint": "^16.26.1",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "yaml-eslint-parser": "^1.3.2"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
